# Security Keys
# OMNIFUSION_SECRET_KEY is required to encrypt/decrypt provider keys stored in database.
# Generate a new key using: uv run omnifusion genkey
OMNIFUSION_SECRET_KEY=YOUR_FERNET_SECRET_KEY

# Password to log in to the /admin web panel
OMNIFUSION_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# API keys authorized to make /v1/chat/completions request calls.
# Fix #19: Supports BOTH formats:
#   Comma-separated (recommended for .env files):  OMNIFUSION_API_KEYS=key_one,key_two
#   JSON array (also accepted):                    OMNIFUSION_API_KEYS=["key_one","key_two"]
OMNIFUSION_API_KEYS=key_one,key_two

# Egress and Multiworker controls
OMNIFUSION_UNSAFE_ALLOW_MULTIWORKER=0
OMNIFUSION_ALLOW_PRIVATE_EGRESS=0

# Security: Set to 1 when running behind HTTPS in production
# This makes the admin session cookie Secure-flagged (required for HTTPS)
OMNIFUSION_SECURE_COOKIE=0

# Budget limits
GLOBAL_DAILY_BUDGET_USD=100.0
REQUEST_BUDGET_USD=10.0

# Request limits (DoS protection)
OMNIFUSION_WALL_TIMEOUT=90
OMNIFUSION_MAX_CONCURRENT_PER_KEY=5
OMNIFUSION_MAX_TOKENS_LIMIT=1000000
OMNIFUSION_MAX_REQUEST_BODY_BYTES=1000000

# Default configuration overrides (YAML import fallback)
# DB Path (Defaults to data/omnifusion.db)
DB_PATH=data/omnifusion.db
