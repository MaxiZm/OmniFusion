# Fix (medium): Prevent sensitive files from being baked into Docker image layers.

# Never bake secrets into the image
.env
.env.local
.env.*.local

# Don't include local database files
data/
*.db
*.db-wal
*.db-shm

# Don't include version control history
.git/
.gitignore

# Don't include Python virtual environment
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version

# Don't include development/test artifacts
.ruff_cache/
.pytest_cache/
.mypy_cache/
tests/
*.test.db

# Don't include IDE config
.vscode/
.idea/

# Don't include local build artifacts
dist/
build/
*.egg-info/

# Don't include README and other docs (optional, keeps image lean)
# README.md
# LICENSE
